#!/bin/bash
################################################################################
# COWADAPT Pipeline - Central Configuration
#
# This is the single source of truth for all pipeline paths and parameters.
# Source this file in all scripts:
#
#   SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
#   source "${SCRIPT_DIR}/config/pipeline.config"
#
################################################################################

set -u

# ============================================================================
# AUTOMATIC DIRECTORY DETECTION
# ============================================================================
# Detect project root automatically based on config file location
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# ============================================================================
# DATA DIRECTORIES
# ============================================================================

# Main data directory
DATA_DIR="${PROJECT_ROOT}/data"

# Input BAM files (long-read sequencing data)
RAW_BAM_DIR="${DATA_DIR}/raw/bams"

# Reference data
REFERENCE_DIR="${DATA_DIR}/reference"

# ============================================================================
# REFERENCE FILES (MUST EXIST BEFORE RUNNING PIPELINE)
# ============================================================================

# ARS-UCD2.0 Reference Genome (FASTA)
REFERENCE_GENOME="${REFERENCE_DIR}/ARS-UCD2.0_genomic.fa"

# Reference Genome Index (created by samtools faidx)
REFERENCE_INDEX="${REFERENCE_GENOME}.fai"

# BovineHD SNP chip positions (BED format)
# Must be in ARS-UCD2.0 coordinates
BOVINE_HD_BED="${REFERENCE_DIR}/bovine_hd_chip/bovineHD_ARS-UCD2.0.bed"

# Zebu-Specific SNP map (Kasarapu et al. 2017)
# Contains Indicine/Taurine ancestry probabilities
ZEBU_SNPMAP="${REFERENCE_DIR}/zebu_snpmap/SNPmap_IND_TAU_ARS.txt"

# VEP (Variant Effect Predictor) Cache
# Contains annotation data for Bos taurus ARS-UCD2.0
VEP_CACHE_DIR="${REFERENCE_DIR}/vep_cache"
VEP_SPECIES_CACHE="${VEP_CACHE_DIR}/bos_taurus"

# ============================================================================
# OUTPUT/RESULTS DIRECTORIES
# ============================================================================

# Main results directory
RESULTS_DIR="${PROJECT_ROOT}/results"

# Step 1: SV Calling outputs (Sniffles2 + SVIM)
SV_CALLS_DIR="${RESULTS_DIR}/sv_calls"
SV_SNIFFLES_DIR="${SV_CALLS_DIR}/sniffles2"
SV_SVIM_DIR="${SV_CALLS_DIR}/svim"

# Step 2: SV Merge & Concordance (SURVIVOR)
SV_MERGE_DIR="${RESULTS_DIR}/sv_merge"

# Step 3: Read-Based Validation
VALIDATION_DIR="${RESULTS_DIR}/validation"

# Step 4: Functional Annotation (VEP)
ANNOTATION_DIR="${RESULTS_DIR}/annotation"

# Step 5: SNP Extraction (BovineHD)
SNP_EXTRACTION_DIR="${RESULTS_DIR}/snp_extraction"

# Step 6: LD Analysis & Tag SNPs
LD_ANALYSIS_DIR="${RESULTS_DIR}/ld_analysis"

# Step 7: Zebu-Specificity Classification
ZEBU_SPECIFICITY_DIR="${RESULTS_DIR}/zebu_specificity"

# Logs directory (all output and error logs)
LOGS_DIR="${PROJECT_ROOT}/logs"

# ============================================================================
# CONFIGURATION DIRECTORIES
# ============================================================================

# Configuration files
CONFIG_DIR="${PROJECT_ROOT}/config"

# Sample metadata (sample_id, bam_file, breed, phenotype, notes)
SAMPLE_MANIFEST="${CONFIG_DIR}/sample_manifest.txt"

# Parameter configuration
PARAMETERS_YAML="${CONFIG_DIR}/parameters.yaml"

# ============================================================================
# SOURCE CODE DIRECTORIES
# ============================================================================

# Main source code
SRC_DIR="${PROJECT_ROOT}/src"

# Utility scripts
UTILS_DIR="${SRC_DIR}/utils"

# Analysis step directories
STEP_01_DIR="${SRC_DIR}/01_sv_calling"
STEP_02_DIR="${SRC_DIR}/02_sv_merge"
STEP_03_DIR="${SRC_DIR}/03_sv_validation"
STEP_04_DIR="${SRC_DIR}/04_functional_annotation"
STEP_05_DIR="${SRC_DIR}/05_snp_extraction"
STEP_06_DIR="${SRC_DIR}/06_ld_analysis"
STEP_07_DIR="${SRC_DIR}/07_zebu_specificity"

# ============================================================================
# PIPELINE PARAMETERS
# ============================================================================

# ---------- SV CALLING PARAMETERS ----------

# Sniffles2
SNIFFLES_MIN_SV_LENGTH=${SNIFFLES_MIN_SV_LENGTH:-50}      # Minimum SV size (bp)
SNIFFLES_MAPQ=${SNIFFLES_MAPQ:-20}                        # Minimum mapping quality
SNIFFLES_ALLOW_OVERWRITE=true                              # Overwrite existing VCFs

# SVIM
SVIM_MIN_LENGTH=${SVIM_MIN_LENGTH:-50}                    # Minimum SV size (bp)

# ---------- SV MERGE & VALIDATION PARAMETERS ----------

# SURVIVOR merge parameters
SURVIVOR_DISTANCE=${SURVIVOR_DISTANCE:-1000}              # Distance threshold (bp)
SURVIVOR_MIN_CALLERS=${SURVIVOR_MIN_CALLERS:-2}          # Minimum caller support
SURVIVOR_MIN_SIZE=${SURVIVOR_MIN_SIZE:-50}                # Minimum SV size (bp)
SURVIVOR_SEQUENCE_TYPE=0                                   # 0=symbolic, 1=sequence-resolved

# Read-based validation (SVvalidation.py)
VALIDATION_MIN_READS=${VALIDATION_MIN_READS:-3}           # Minimum supporting reads
VALIDATION_MIN_SPLIT_READS=${VALIDATION_MIN_SPLIT_READS:-2}

# ---------- FUNCTIONAL ANNOTATION PARAMETERS ----------

# VEP (Variant Effect Predictor)
VEP_SPECIES="bos_taurus"                                  # Species for annotation
VEP_ASSEMBLY="ARS-UCD2.0"                                 # Genome assembly
VEP_BUFFER_SIZE=${VEP_BUFFER_SIZE:-5000}                 # VEP buffer size
VEP_FORK=${VEP_FORK:-4}                                   # VEP parallel processes
VEP_PLUGINS="LoFtool,Conservation"                        # VEP plugins to use

# ---------- SNP & LD ANALYSIS PARAMETERS ----------

# LD Analysis (plink2)
LD_R2_THRESHOLD=${LD_R2_THRESHOLD:-0.3}                  # LD R2 threshold for tag SNPs
LD_WINDOW_KB=${LD_WINDOW_KB:-1000}                       # LD window size (kilobases)
LD_WINDOW_SNP=${LD_WINDOW_SNP:-0}                        # LD window SNPs (0=use KB)

# Tag SNP selection
TAG_SNP_MIN_MAF=${TAG_SNP_MIN_MAF:-0.01}                 # Minimum allele frequency

# ---------- ZEBU-SPECIFICITY PARAMETERS ----------

# Ancestry classification thresholds
INDICINE_PROB_THRESHOLD=${INDICINE_PROB_THRESHOLD:-0.5}  # Indicine probability threshold
TAURINE_PROB_THRESHOLD=${TAURINE_PROB_THRESHOLD:-0.5}    # Taurine probability threshold

# ============================================================================
# COMPUTE PARAMETERS
# ============================================================================

# Number of CPU threads to use
THREADS=${THREADS:-8}

# Maximum parallel jobs to run
MAX_PARALLEL_JOBS=${MAX_PARALLEL_JOBS:-4}

# Memory per CPU (for SLURM/SGE)
MEMORY_PER_CPU=${MEMORY_PER_CPU:-4G}

# ============================================================================
# HPC/CLUSTER CONFIGURATION (Optional)
# ============================================================================

# Cluster type: empty (local), "slurm", or "sge"
HPC_TYPE="${HPC_TYPE:-}"

# SLURM-specific
SLURM_PARTITION="${SLURM_PARTITION:-default}"
SLURM_TIME="${SLURM_TIME:-24:00:00}"
SLURM_MEM_PER_CPU="${SLURM_MEM_PER_CPU:-4G}"
SLURM_CPUS="${SLURM_CPUS:-32}"

# ============================================================================
# UTILITY FUNCTIONS
# ============================================================================

# Initialize all output directories
init_directories() {
    mkdir -p "$RAW_BAM_DIR"
    mkdir -p "$SV_SNIFFLES_DIR"
    mkdir -p "$SV_SVIM_DIR"
    mkdir -p "$SV_MERGE_DIR"
    mkdir -p "$VALIDATION_DIR"
    mkdir -p "$ANNOTATION_DIR"
    mkdir -p "$SNP_EXTRACTION_DIR"
    mkdir -p "$LD_ANALYSIS_DIR"
    mkdir -p "$ZEBU_SPECIFICITY_DIR"
    mkdir -p "$LOGS_DIR"
}

# Validate all required reference files exist
check_references() {
    local missing=0

    # Check genome FASTA
    if [ ! -f "$REFERENCE_GENOME" ]; then
        log_error "Reference genome not found: $REFERENCE_GENOME"
        log_error "Download with: bash src/utils/download_reference_genome.sh"
        missing=1
    fi

    # Check genome index
    if [ ! -f "$REFERENCE_INDEX" ]; then
        log_error "Reference index not found: $REFERENCE_INDEX"
        log_error "Create with: samtools faidx $REFERENCE_GENOME"
        missing=1
    fi

    # Check BovineHD chip (warning if missing, but not fatal)
    if [ ! -f "$BOVINE_HD_BED" ]; then
        log_warn "BovineHD chip file not found: $BOVINE_HD_BED"
        log_warn "Step 5 will fail. Download from Illumina or papers."
    fi

    # Check Zebu SNPmap (warning if missing)
    if [ ! -f "$ZEBU_SNPMAP" ]; then
        log_warn "Zebu SNPmap not found: $ZEBU_SNPMAP"
        log_warn "Step 7 will fail. Download from Kasarapu et al. (2017)"
    fi

    # Check VEP cache (warning if missing)
    if [ ! -d "$VEP_SPECIES_CACHE" ]; then
        log_warn "VEP cache not found: $VEP_CACHE_DIR"
        log_warn "Step 4 will fail. Download with: vep_install --AUTO cf --SPECIES bos_taurus --ASSEMBLY ARS-UCD2.0"
    fi

    return $missing
}

# Get number of BAM files
count_bam_files() {
    if [ ! -d "$RAW_BAM_DIR" ]; then
        echo 0
        return
    fi
    find "$RAW_BAM_DIR" -maxdepth 1 -name "*.bam" -type f | wc -l
}

# Log with timestamp and level
log_info() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [INFO] $*"
}

log_warn() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [WARN] $*" >&2
}

log_error() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [ERROR] $*" >&2
}

log_debug() {
    if [ "${DEBUG:-0}" = "1" ]; then
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] [DEBUG] $*" >&2
    fi
}

# Check if a command exists
command_exists() {
    command -v "$1" &> /dev/null
}

# Check if file is readable
file_readable() {
    [ -r "$1" ]
}

# Check if directory exists
dir_exists() {
    [ -d "$1" ]
}

# Load sample list from manifest
load_sample_list() {
    local manifest="${1:-$SAMPLE_MANIFEST}"

    if [ ! -f "$manifest" ]; then
        log_error "Sample manifest not found: $manifest"
        return 1
    fi

    # Skip header (line 1), return BAM file paths (column 2)
    tail -n +2 "$manifest" | cut -f2
}

# Get sample ID from BAM filename
get_sample_id() {
    local bam_file="$1"
    basename "$bam_file" .bam
}

# Verify BAM file is indexed
verify_bam_index() {
    local bam="$1"

    if [ ! -f "$bam" ]; then
        log_error "BAM file not found: $bam"
        return 1
    fi

    if [ ! -f "${bam}.bai" ]; then
        log_warn "BAM index not found, creating: ${bam}.bai"
        samtools index -@ "$THREADS" "$bam"
    fi

    return 0
}

# Get file size in human-readable format
get_file_size() {
    du -h "$1" | cut -f1
}

# ============================================================================
# EXPORT VARIABLES
# ============================================================================
# Make all variables available to child processes

export PROJECT_ROOT
export DATA_DIR RAW_BAM_DIR REFERENCE_DIR
export REFERENCE_GENOME REFERENCE_INDEX BOVINE_HD_BED ZEBU_SNPMAP VEP_CACHE_DIR
export RESULTS_DIR
export SV_CALLS_DIR SV_SNIFFLES_DIR SV_SVIM_DIR SV_MERGE_DIR
export VALIDATION_DIR ANNOTATION_DIR SNP_EXTRACTION_DIR LD_ANALYSIS_DIR ZEBU_SPECIFICITY_DIR
export LOGS_DIR
export CONFIG_DIR SAMPLE_MANIFEST PARAMETERS_YAML
export SRC_DIR UTILS_DIR
export STEP_01_DIR STEP_02_DIR STEP_03_DIR STEP_04_DIR STEP_05_DIR STEP_06_DIR STEP_07_DIR

export SNIFFLES_MIN_SV_LENGTH SNIFFLES_MAPQ SVIM_MIN_LENGTH
export SURVIVOR_DISTANCE SURVIVOR_MIN_CALLERS
export VEP_SPECIES VEP_ASSEMBLY VEP_BUFFER_SIZE VEP_FORK
export LD_R2_THRESHOLD LD_WINDOW_KB
export THREADS MAX_PARALLEL_JOBS MEMORY_PER_CPU
export HPC_TYPE SLURM_PARTITION SLURM_TIME SLURM_MEM_PER_CPU SLURM_CPUS

################################################################################
# END OF CONFIG
################################################################################
